# Resend - serverless Vercel only
RESEND_API_KEY=
RESEND_FROM_EMAIL="Cahier <notifications@your-domain.com>"
RESEND_DEFAULT_TO_EMAIL=

# Upstash Redis (Vercel Marketplace). L'intégration peut injecter les noms KV_REST_API_* :
# les deux paires sont acceptées par api/_lib/redis.ts.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Authentification (JWT) — chaîne aléatoire de 32 caractères minimum
AUTH_SECRET=

# Code secret d'accès au dashboard admin (/admin.html)
ADMIN_SECRET=

# Web Push (générer avec: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:contact@your-domain.com"
VITE_VAPID_PUBLIC_KEY=

# Secret du cron Vercel (/api/notify) — chaîne aléatoire de 32 caractères minimum
CRON_SECRET=
